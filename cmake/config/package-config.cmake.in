
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(arba-core 0.30.0 CONFIG)
find_dependency(arba-stdx 0.3.0 CONFIG)
find_dependency(arba-rsce 0.5.0 CONFIG)
find_dependency(arba-evnt 0.7.0 CONFIG)
if(@ARBA_APPT_USE_SPDLOG@)
    find_dependency(spdlog 1.8 CONFIG)
endif()

set(component_list
    feature
    toto
    titi
)

#set(component_feature_deps "arba-core 0.30.0;arba-stdx 0.3.0")

include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)
if(NOT TARGET "@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@@LIBRARY_TYPE_POSTFIX@")
  add_library("@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@@LIBRARY_TYPE_POSTFIX@" ALIAS @PROJECT_NAME@@LIBRARY_TYPE_POSTFIX@)
endif()

foreach(component ${component_list})
    if(${component} IN_LIST @PROJECT_NAME@_FIND_COMPONENTS)
        set(targets_file ${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-${component}-targets.cmake)
        if(EXISTS ${targets_file})
            include(${targets_file})
            set(@PROJECT_NAME@_${component}_FOUND TRUE)
            message(STATUS "Found @PROJECT_NAME@ component: ${component}")
        else()
            if(@PROJECT_NAME@_FIND_REQUIRED_${component})
                message(SEND_ERROR "Missing required @PROJECT_NAME@ component: ${component}")
            else()
                message(WARNING "Missing optional @PROJECT_NAME@ component: ${component}")
            endif()
        endif()
    else()
        if(@PROJECT_NAME@_FIND_REQUIRED_${component})
            message(SEND_ERROR "Unknown required @PROJECT_NAME@ component: ${component}")
        else()
            message(WARNING "Unknown optional @PROJECT_NAME@ component: ${component}")
        endif()
    endif()
endforeach()

check_required_components(@PROJECT_NAME@)

if(NOT DEFINED @PROJECT_NAME@_FOUND)
    set(@PROJECT_NAME@_FOUND TRUE)
    foreach(component ${component_list})
        if(@PROJECT_NAME@_${component}_FOUND)
            if(NOT TARGET "@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@-${component}@LIBRARY_TYPE_POSTFIX@")
                add_library("@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@-${component}@LIBRARY_TYPE_POSTFIX@" ALIAS @PROJECT_NAME@-${component}@LIBRARY_TYPE_POSTFIX@)
                message(STATUS "Alias created for @PROJECT_NAME@ component: ${component}")
            endif()
        endif()
    endforeach()
    message(STATUS "Found package @PROJECT_NAME@ @PROJECT_VERSION@")
endif()
