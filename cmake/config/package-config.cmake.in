
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(arba-core 0.30.0 CONFIG)
find_dependency(arba-stdx 0.3.0 CONFIG)
find_dependency(arba-rsce 0.5.0 CONFIG)
find_dependency(arba-evnt 0.7.0 CONFIG)
if(@ARBA_APPT_USE_SPDLOG@)
    find_dependency(spdlog 1.8 CONFIG)
endif()

if(NOT TARGET "@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@@LIBRARY_TYPE_POSTFIX@")
  include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake)
  add_library("@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@@LIBRARY_TYPE_POSTFIX@" ALIAS @PROJECT_TARGET_NAME@)
endif()

set(component_list
    feature
)

message(STATUS "FIND_COMPONENTS: ${arba-appt_FIND_COMPONENTS}")
foreach(component ${component_list})
    if(${component} IN_LIST arba-appt_FIND_COMPONENTS)
        message(STATUS "Check component ${component}")
        set(targets_file ${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@_${component}-targets.cmake)
        if(EXISTS ${targets_file})
            include(${targets_file})
            set(arba-appt_${component}_FOUND TRUE)
            message(STATUS "Found component ${component}")
            if(NOT TARGET "@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@_feature@LIBRARY_TYPE_POSTFIX@")
            endif()
        else()
            message(ERROR "Missing component ${component}")
        endif()
    endif()
endforeach()

#foreach(component ${arba-appt_FIND_COMPONENTS})
#    include(${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@_${component}-targets.cmake)
#endforeach()
check_required_components(arba-appt)

  add_library("@PROJECT_NAMESPACE@::@PROJECT_FEATURE_NAME@_feature@LIBRARY_TYPE_POSTFIX@" ALIAS @PROJECT_TARGET_NAME@_feature)
endif()

message(STATUS "Found package @PROJECT_NAME@ @PROJECT_VERSION@")
